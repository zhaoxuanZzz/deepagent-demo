# 复制为 .env: cp .env.example .env

# --- Tavily（联网搜索，本 demo 必填）---
TAVILY_API_KEY=

# --- Minimax：官方 OpenAI 兼容（推荐，与控制台文档一致）---
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=
# 模型 ID，与 Minimax 控制台一致，例如 MiniMax-M2.7
MINIMAX_MODEL=MiniMax-M2.7
# 可选，与 MINIMAX_MODEL 二选一优先读 OPENAI_MODEL
# OPENAI_MODEL=

# --- 可选：未配 OPENAI_* 时，使用 LangChain MiniMaxChat 原生接口 ---
# MINIMAX_API_KEY=
# MINIMAX_API_HOST=https://api.minimaxi.chat/v1/text/chatcompletion_v2

# --- 可选：显式指定其它厂商模型 ---
# DEEPAGENTS_MODEL=

# --- 可选：Deep Agents 后端 / execute 工具 ---
# state（默认）：文件在图状态内，不提供 execute
# local：LocalShellBackend，启用 execute（在宿主机执行，仅可信环境）
# DEEPAGENTS_SANDBOX=state
# DEEPAGENTS_SANDBOX=local
# local 时 ls/execute 默认以项目根为虚拟根；若要空目录隔离可自建目录并传：
# uv run python main.py --sandbox local --sandbox-workspace ./.deepagent_sandbox_workspace

# --- 以上均未配置时，deepagents 默认 Anthropic ---
# ANTHROPIC_API_KEY=
