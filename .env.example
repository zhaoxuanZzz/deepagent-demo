# 复制为 .env: cp .env.example .env

# --- Tavily（联网搜索，本 demo 必填）---
TAVILY_API_KEY=

# --- Minimax：官方 OpenAI 兼容（推荐，与控制台文档一致）---
OPENAI_BASE_URL=https://api.minimaxi.com/v1
OPENAI_API_KEY=
# 模型 ID，与 Minimax 控制台一致，例如 MiniMax-M2.7
MINIMAX_MODEL=MiniMax-M2.7
# 可选，与 MINIMAX_MODEL 二选一优先读 OPENAI_MODEL
# OPENAI_MODEL=

# --- 可选：未配 OPENAI_* 时，使用 LangChain MiniMaxChat 原生接口 ---
# MINIMAX_API_KEY=
# MINIMAX_API_HOST=https://api.minimaxi.chat/v1/text/chatcompletion_v2

# --- 可选：显式指定其它厂商模型 ---
# DEEPAGENTS_MODEL=

# --- 可选：沙箱模式 state（默认）| local | docker ---
# DEEPAGENTS_SANDBOX=docker
#
# Docker（默认）：启动时把宿主目录复制到容器 /workspace/project；/workspace 为容器 tmpfs；源码不挂载进容器。
# DOCKER_SANDBOX_IMAGE=python:3.12-slim
# DOCKER_SANDBOX_NETWORK=none
# DOCKER_SANDBOX_CODE_ROOT=/path/to/repo
#
# Docker（用户级持久工作区）：与上互斥。容器名 deepagent-u-{slug}、命名卷 deepagent-data-{slug} -> /workspace；
# 宿主代码只读挂 /project（源码根见 DOCKER_SANDBOX_CODE_ROOT，默认同仓库根）。
# DOCKER_SANDBOX_USER_ID=alice

# --- 以上均未配置时，deepagents 默认 Anthropic ---
# ANTHROPIC_API_KEY=
